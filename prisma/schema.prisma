// PostgreSQL + TimescaleDB Schema for OSINT Fusion Platform
// TimescaleDB extension enabled for time-series data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core entity table - current state (not time-series)
model Entity {
  id          String   @id
  label       String
  type        EntityType
  provider    String
  
  // Current position
  lat         Float
  lon         Float
  alt         Float?
  
  // Dynamics
  heading     Float    @default(0)
  speed       Float    @default(0)
  
  // Metadata as JSONB for flexibility
  meta        Json?
  
  // Timestamps
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @updatedAt
  
  // Relations
  history     EntityHistory[]
  alerts      Alert[]
  
  @@index([type])
  @@index([provider])
  @@index([lastSeen])
  @@map("entities")
}

// Time-series entity history - TimescaleDB hypertable
model EntityHistory {
  id          String   @id @default(uuid())
  entityId    String
  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  
  // Position at this point in time
  lat         Float
  lon         Float
  alt         Float?
  
  // Dynamics
  heading     Float
  speed       Float
  
  // Timestamp - this is the time-series key
  timestamp   DateTime @default(now())
  
  // Data quality / source info
  source      String   @default("unknown")
  accuracy    Float?   // Position accuracy in meters
  
  @@index([entityId])
  @@index([timestamp])
  @@index([entityId, timestamp])
  @@map("entity_history")
}

// Geo events - natural disasters, weather, etc.
model GeoEvent {
  id          String   @id @default(uuid())
  externalId  String?  // ID from source system
  title       String
  type        GeoEventType
  severity    Severity   @default(medium)
  
  // Location
  lat         Float
  lon         Float
  radius      Float?     // Affected radius in km
  
  // Event details
  description String?
  source      String     // USGS, GDACS, NASA, etc.
  sourceUrl   String?
  
  // Timestamps
  eventTime   DateTime
  detectedAt  DateTime   @default(now())
  expiresAt   DateTime?  // When event is no longer relevant
  
  // Related entities (JSON array of entity IDs)
  relatedEntities Json?
  
  @@index([type])
  @@index([severity])
  @@index([eventTime])
  @@index([detectedAt])
  @@map("geo_events")
}

// Market alerts and financial events
model MarketAlert {
  id          String   @id @default(uuid())
  symbol      String
  name        String?
  type        MarketAlertType
  
  // Price data
  price       Float
  change24h   Float
  changePercent24h Float
  
  // Alert details
  message     String
  severity    Severity   @default(medium)
  
  // Source
  source      String     @default("coingecko")
  
  // Timestamp
  timestamp   DateTime   @default(now())
  
  @@index([symbol])
  @@index([type])
  @@index([timestamp])
  @@map("market_alerts")
}

// Fusion relations - links between entities
model FusionRelation {
  id          String   @id @default(uuid())
  entityAId   String
  entityBId   String
  
  // Relation type and strength
  type        RelationType
  strength    Float      // 0.0 to 1.0 confidence
  
  // Detection method and context
  method      String     // proximity, temporal, pattern, etc.
  context     Json?      // Additional relation context
  
  // Time window for this relation
  startTime   DateTime   @default(now())
  endTime     DateTime?  // Null if still active
  
  // Timestamps
  detectedAt  DateTime   @default(now())
  
  @@index([entityAId])
  @@index([entityBId])
  @@index([type])
  @@index([detectedAt])
  @@map("fusion_relations")
}

// Sightings - aircraft/vessel proximity events for investigative use
model Sighting {
  id          String   @id @default(uuid())
  
  // Entity A (aircraft)
  entityAId   String
  entityAType String   // aircraft
  entityALabel String
  entityALat  Float
  entityALon  Float
  entityAAlt  Float?
  entityAHeading Float?
  entityASpeed   Float?
  
  // Entity B (vessel)
  entityBId   String
  entityBType String   // vessel
  entityBLabel String
  entityBLat  Float
  entityBLon  Float
  entityBHeading Float?
  entityBSpeed   Float?
  
  // Proximity data
  distanceKm  Float    // Distance between entities in km
  proximityRadiusKm Float @default(50)  // Threshold that triggered this sighting
  
  // Context
  durationSeconds Int?   // How long they stayed within proximity
  correlationScore Float? // Fusion confidence
  
  // Investigation notes (added by analysts)
  notes       String?
  tags        String[]  // Array of tags
  
  // AI Analysis
  aiSummary   String?   // AI-generated pattern analysis
  aiRiskScore Float?    // 0-1 risk assessment
  
  // Status for workflow
  status      SightingStatus @default(detected)
  reviewedBy  String?
  reviewedAt  DateTime?
  
  // Timestamps
  detectedAt  DateTime @default(now())
  firstSeen   DateTime  // When they first came within proximity
  lastSeen    DateTime? // When they left proximity
  
  @@index([entityAId])
  @@index([entityBId])
  @@index([entityAType, entityBType])
  @@index([distanceKm])
  @@index([detectedAt])
  @@index([status])
  @@index([aiRiskScore])
  @@map("sightings")
}

// System alerts and notifications
model Alert {
  id          String   @id @default(uuid())
  type        AlertType
  severity    Severity
  
  // Content
  title       String
  message     String
  
  // Related entity (optional)
  entityId    String?
  entity      Entity?  @relation(fields: [entityId], references: [id])
  
  // Location (for geo alerts)
  lat         Float?
  lon         Float?
  
  // Status
  acknowledged Boolean @default(false)
  dismissed    Boolean @default(false)
  
  // Timestamps
  createdAt   DateTime @default(now())
  acknowledgedAt DateTime?
  
  @@index([type])
  @@index([severity])
  @@index([createdAt])
  @@index([acknowledged])
  @@map("alerts")
}

// API health and rate limit tracking
model ApiHealth {
  id          String   @id @default(uuid())
  provider    String   // opensky, adsb-fi, celestrak, etc.
  endpoint    String?
  
  // Status
  status      ApiStatus @default(unknown)
  lastSuccess DateTime?
  lastFailure DateTime?
  
  // Error tracking
  errorCount  Int      @default(0)
  lastError   String?
  
  // Rate limiting
  rateLimitRemaining Int?
  rateLimitReset     DateTime?
  
  // Response time tracking (ms)
  avgResponseTime Float?
  
  // Timestamp
  checkedAt   DateTime @default(now())
  
  @@index([provider])
  @@index([status])
  @@index([checkedAt])
  @@map("api_health")
}

// Enums
enum EntityType {
  aircraft
  vessel
  satellite
  ground_station
  unknown
}

enum GeoEventType {
  earthquake
  flood
  wildfire
  storm
  volcanic
  landslide
  drought
  tsunami
  other
}

enum MarketAlertType {
  spike
  crash
  volume_anomaly
  pattern_detected
  other
}

enum Severity {
  low
  medium
  high
  critical
}

enum RelationType {
  proximity      // Entities near each other
  temporal       // Active at same time
  correlated     // Movement patterns match
  suspicious     // Anomalous behavior detected
  associated     // Known association
}

enum AlertType {
  disaster
  market
  fusion
  weather
  system
  anomaly
}

enum ApiStatus {
  healthy
  degraded
  error
  rate_limited
  unknown
}

enum SightingStatus {
  detected
  investigating
  confirmed
  dismissed
  false_positive
}
