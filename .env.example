# OSINT Platform v2 -- Environment Variables
# Copy this file to .env and fill in your API keys.
#
# Without any keys, the platform runs in DEMO mode with simulated entities.
# Set VITE_LIVE_MODE=true to connect to free/open feeds even without keys.

# ---- Mode control ----
# VITE_DEMO_MODE=true        # Force demo simulation
# VITE_LIVE_MODE=true        # Force live connections (uses free feeds)

# ---- Aircraft telemetry ----
# WITHOUT a key: uses OpenSky Network REST API (FREE, no signup, no key)
#   https://openskynetwork.github.io/opensky-api/
# WITH a key: uses ADS-B Exchange WebSocket (premium, faster updates)
#   Get a key from https://www.adsbexchange.com/data/
VITE_ADSB_WS_URL=wss://opendata.adsb.fi/api/v2/websocket
VITE_ADSB_API_KEY=

# ---- AIS / Maritime (vessel telemetry) ----
# Get a FREE API key from https://aisstream.io/ (sign up required)
# Provides global AIS vessel tracking via WebSocket
VITE_AIS_WS_URL=wss://stream.aisstream.io/v0/stream
VITE_AIS_API_KEY=

# ---- Supabase (existing integration) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- PostgreSQL + TimescaleDB (for persistence) ----
# Format: postgresql://user:password@host:port/database?schema=public
# For local development: postgresql://postgres:postgres@localhost:5432/osint?schema=public
DATABASE_URL=

# ---- Data retention settings ----
# How many days to keep entity history (TimescaleDB will auto-compress older chunks)
HISTORY_RETENTION_DAYS=30
# Buffer size for batch inserts (default: 100)
DB_BUFFER_SIZE=100
# Buffer flush interval in milliseconds (default: 5000)
DB_FLUSH_INTERVAL_MS=5000
