# OSINT Platform v2 -- Environment Variables
# Copy this file to .env and fill in your API keys.
#
# Without any keys, the platform runs in DEMO mode with simulated entities.
# Set VITE_LIVE_MODE=true to connect to free/open feeds even without keys.

# ---- Mode control ----
# VITE_DEMO_MODE=true        # Force demo simulation
# VITE_LIVE_MODE=true        # Force live connections (uses free feeds)

# ---- ADS-B Exchange (aircraft telemetry) ----
# Default endpoint: opendata.adsb.fi (FREE, no key required)
# For premium access, get a key from https://www.adsbexchange.com/data/
VITE_ADSB_WS_URL=wss://opendata.adsb.fi/api/v2/websocket
VITE_ADSB_API_KEY=

# ---- AIS / Maritime (vessel telemetry) ----
# Get a FREE API key from https://aisstream.io/ (sign up required)
# Provides global AIS vessel tracking via WebSocket
VITE_AIS_WS_URL=wss://stream.aisstream.io/v0/stream
VITE_AIS_API_KEY=

# ---- Supabase (existing integration) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
